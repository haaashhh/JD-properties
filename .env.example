# Supabase — copy these from your project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# QuickBooks (Module 6 — provision the secret now, plumbing wired later).
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QB_ENVIRONMENT=sandbox

# 32-byte base64 key used to encrypt QuickBooks tokens at rest.
# Generate with: openssl rand -base64 32
QB_TOKEN_ENC_KEY=
